{
    "version": 2,
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api"
        },
        {
            "source": "/uploads/(.*)",
            "destination": "/api"
        },
        {
            "source": "/((?!api|uploads).*)",
            "destination": "/frontend/dist/$1"
        }
    ]
}